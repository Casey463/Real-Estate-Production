# Copy this file to terraform.tfvars (or pass -var/-var-file in CI)
# and replace values for your environment.

aws_region         = "us-west-2"
aws_account_id     = "123456789012"
cluster_name       = "real-estate-eks"
frontend_image_tag = "latest"
backend_image_tag  = "latest"

# Optional: set ACM certificate ARN to enable HTTPS listeners (443) on frontend/backend services.
acm_certificate_arn = ""

# Network values (keep defaults or customize).
vpc_cidr_block       = "10.0.0.0/16"
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnet_cidrs = ["10.0.101.0/24", "10.0.102.0/24"]
availability_zones   = ["us-west-2a", "us-west-2b"]

# Kubernetes secret values.
backend_env_secret_values = {
	DB_NAME           = "replace_me"
	DB_USER           = "replace_me"
	DB_PASSWORD       = "replace_me"
	DB_HOST           = "replace_me"
	DB_PORT           = "5432"
	BACKEND_URL       = "https://replace-me.example.com"
	FRONTEND_URL      = "https://replace-me.example.com"
}

frontend_env_secret_values = {
	NEXT_PUBLIC_BASE_API_URL = "https://replace-me.example.com"
}
